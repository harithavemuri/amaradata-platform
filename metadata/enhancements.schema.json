{
  "table": "enhancements",
  "columns": [
    { "name": "id",               "type": "integer",    "primaryKey": true, "autoIncrement": true },
    { "name": "tenant_id",        "type": "integer",    "nullable": false,  "references": "tenants.id" },
    { "name": "title",            "type": "varchar",    "nullable": false,  "length": 255 },
    { "name": "description",      "type": "text",       "nullable": true },
    { "name": "billing_type",     "type": "varchar",    "nullable": false,  "length": 50,  "default": "hourly", "enum": ["hourly","milestone","fixed"] },
    { "name": "status",           "type": "varchar",    "nullable": false,  "length": 50,  "default": "scoped", "enum": ["scoped","in_progress","delivered","billed","cancelled"] },
    { "name": "estimated_hours",  "type": "numeric",    "nullable": true,   "precision": 7,  "scale": 2 },
    { "name": "actual_hours",     "type": "numeric",    "nullable": true,   "precision": 7,  "scale": 2 },
    { "name": "hourly_rate",      "type": "numeric",    "nullable": true,   "precision": 10, "scale": 2 },
    { "name": "milestone_amount", "type": "numeric",    "nullable": true,   "precision": 12, "scale": 2 },
    { "name": "delivered_at",     "type": "date",       "nullable": true },
    { "name": "invoice_id",       "type": "integer",    "nullable": true,   "references": "invoices.id" },
    { "name": "notes",            "type": "text",       "nullable": true },
    { "name": "source",           "type": "varchar",    "nullable": false,  "length": 20,  "default": "manual", "enum": ["manual","csv"] },
    { "name": "issue_id",         "type": "integer",    "nullable": true },
    { "name": "site_name",        "type": "varchar",    "nullable": true,   "length": 100 },
    { "name": "fixed",            "type": "varchar",    "nullable": true,   "length": 200 },
    { "name": "item_type",        "type": "varchar",    "nullable": false,  "length": 50,  "default": "enhancement", "enum": ["bug","enhancement"] },
    { "name": "is_billable",      "type": "boolean",    "nullable": false,  "default": true },
    { "name": "report_date",      "type": "date",       "nullable": true },
    { "name": "created_at",       "type": "timestamp",  "nullable": false,  "default": "NOW()" },
    { "name": "updated_at",       "type": "timestamp",  "nullable": false,  "default": "NOW()" }
  ],
  "uniqueConstraints": [
    { "columns": ["tenant_id", "issue_id"], "note": "NULLs not considered equal — manual rows unaffected" }
  ]
}
