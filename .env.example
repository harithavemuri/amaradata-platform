# AmaraData Platform — copy to .env and fill in values

PORT=9000
NODE_ENV=development

# Platform database (Aurora Serverless v2 in prod; local PostgreSQL for dev)
AMRD_DB_HOST=localhost
AMRD_DB_PORT=5432
AMRD_DB_NAME=amaradata_platform

# Single user (dev shorthand) — OR use separate read/write users below
AMRD_DB_USER=postgres
AMRD_DB_PASSWORD=your_password

# Separate read/write users (recommended; override single user above)
# AMRD_DB_WRITE_USER=amrd_write
# AMRD_DB_WRITE_PASSWORD=write_password
# AMRD_DB_READ_USER=amrd_read
# AMRD_DB_READ_PASSWORD=read_password

# JWT secret for staff sessions
AMRD_JWT_SECRET=change_me_to_a_long_random_string

# File-based mode (no DB required) — set to 'true' to enable
NONDB_MODE=false

# Paths for NonDB data files (defaults shown)
# METADATA_DIR=./metadata
# TRANSACTIONDATA_DIR=./transactiondata

# AWS region (for Secrets Manager and SAM deployment)
# AWS_REGION=ap-south-1
