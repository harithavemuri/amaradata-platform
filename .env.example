# AmaraData Platform — copy to .env and fill in values

PORT=9000

# AmaraData platform database (separate from any tenant DB)
AMRD_DB_HOST=localhost
AMRD_DB_PORT=5432
AMRD_DB_NAME=amaradata_platform
AMRD_DB_USER=postgres
AMRD_DB_PASSWORD=your_password

# JWT secret for platform staff sessions
AMRD_JWT_SECRET=change_me_to_a_long_random_string

# Optional: encryption key for storing tenant DB credentials
AMRD_ENCRYPT_KEY=change_me_to_32_char_key_here___

NODE_ENV=development
