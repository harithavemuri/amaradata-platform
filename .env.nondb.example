# AmaraData Platform — NonDB (file-based) mode
# No PostgreSQL required. All data is read from / written to transactiondata/*.json.
#
# Usage:
#   cp .env.nondb.example .env
#   npm run dev:nondb
#   # or: NONDB_MODE=true npm start

PORT=9000
NODE_ENV=development

# File-based data layer
NONDB_MODE=true
METADATA_DIR=./metadata
TRANSACTIONDATA_DIR=./transactiondata

# JWT secret (still required for auth)
AMRD_JWT_SECRET=change_me_to_a_long_random_string

# DB vars not needed in NonDB mode but set to avoid startup warnings
AMRD_DB_HOST=localhost
AMRD_DB_PORT=5432
AMRD_DB_NAME=amaradata_platform
AMRD_DB_USER=postgres
AMRD_DB_PASSWORD=
